# tests/tcyr/nf4.tcyr — M4 NF4 codec: exactness properties.
#
# The codec is forward-only (no gradient), so the gate is exactness, not FD:
#   * known answers: 0 -> code 7 (exact 0.0 back); ±absmax -> codes 0/15 (±scale)
#   * every NF4 table value round-trips through quantize EXACTLY (snaps to itself)
#   * round-trip error bound: |w − deq(quant(w))| ≤ half the largest quantile
#     gap × block absmax (largest gap is the NEGATIVE side's −1.0 → −0.69619…
#     → bound 0.15190·amax)
#   * requant idempotence: quant(dequant(codes)) reproduces the codes + scales
#   * pack/unpack: 2-codes-per-byte get/set identity
#   * double-quant: reconstructed scales within amax/254 of the originals
include "src/lib.cyr"
include "lib/assert.cyr"

fn _absf(x): i64 { if (f64_lt(x, f64_from(0)) == 1) { return f64_neg(x); } return x; }

# deterministic fill in [-1.5, 1.5]
fn _fill(p, n): i64 {
    var i = 0;
    while (i < n) {
        var q = ((i * 37 + 11) % 61);
        var x = f64_sub(f64_div(f64_from(q * 3), f64_from(61)), f64_div(f64_from(3), f64_from(2)));
        store64(p + i * 8, x);
        i = i + 1;
    }
    return 0;
}

fn test_nf4(): i64 {
    var bs = NF4_BS();

    # ---- known answers on one exact block -------------------------------------
    var W = t_alloc(bs);
    t_zero(W, bs);
    store64(W + 0 * 8, f64_from(3));                     # +absmax -> code 15 -> +scale
    store64(W + 1 * 8, f64_neg(f64_from(3)));            # -absmax -> code 0  -> -scale
    var codes = alloc(bs / 2 + 1);
    var scales = t_alloc(1);
    nf4_quant(W, bs, codes, scales);
    assert(f64_eq(load64(scales), f64_from(3)), "scale == block absmax");
    var deq = t_alloc(bs);
    nf4_dequant(codes, scales, bs, deq);
    assert(f64_eq(load64(deq + 0 * 8), f64_from(3)), "+absmax round-trips exactly");
    assert(f64_eq(load64(deq + 1 * 8), f64_neg(f64_from(3))), "-absmax round-trips exactly");
    assert(f64_eq(load64(deq + 2 * 8), f64_from(0)), "0.0 round-trips exactly (code 7)");

    # ---- every table value snaps to itself ------------------------------------
    var i = 0;
    var self_ok = 1;
    while (i < 16) {
        if (nf4_code(nf4_value(i)) != i) { self_ok = 0; }
        i = i + 1;
    }
    assert_eq(self_ok, 1, "all 16 NF4 quantiles quantize to themselves");

    # ---- round-trip error bound over multi-block data --------------------------
    var n = 3 * bs + 17;                                  # multi-block + ragged tail
    var W2 = t_alloc(n);
    _fill(W2, n);
    var nb = (n + bs - 1) / bs;
    var codes2 = alloc(n / 2 + 1);
    var scales2 = t_alloc(nb);
    nf4_quant(W2, n, codes2, scales2);
    var deq2 = t_alloc(n);
    nf4_dequant(codes2, scales2, n, deq2);
    # bound: half the largest adjacent-quantile gap — the NEGATIVE side's
    # (−1.0 → −0.6961928…) = 0.3038072/2 = 0.1519036 (bigger than the positive
    # side's 0.1385216: 8 negative levels cover more span than 7 positive + 0)
    var halfgap = f64_div(f64_from(15190359950066562), f64_from(100000000000000000));
    var bad = 0;
    i = 0;
    while (i < n) {
        var amax = load64(scales2 + (i / bs) * 8);
        var err = _absf(f64_sub(load64(W2 + i * 8), load64(deq2 + i * 8)));
        var lim = f64_mul(f64_add(halfgap, f64_div(f64_from(1), f64_from(1000000))), amax);
        if (f64_gt(err, lim) == 1) { bad = bad + 1; }
        i = i + 1;
    }
    assert_eq(bad, 0, "round-trip error <= max-half-gap x block absmax, every element");

    # ---- requant idempotence ----------------------------------------------------
    var codes3 = alloc(n / 2 + 1);
    var scales3 = t_alloc(nb);
    nf4_quant(deq2, n, codes3, scales3);
    var cd = 0;
    i = 0;
    while (i < n) { if (load8(codes2 + i / 2) != load8(codes3 + i / 2)) { cd = cd + 1; } i = i + 1; }
    var sd = 0;
    i = 0;
    while (i < nb) { if (load64(scales2 + i * 8) != load64(scales3 + i * 8)) { sd = sd + 1; } i = i + 1; }
    assert_eq(cd + sd, 0, "requantizing the dequantized data is idempotent (codes + scales)");

    # ---- double-quant error bound ------------------------------------------------
    var q8 = alloc(nb);
    var supers = t_alloc((nb + NF4_SBS() - 1) / NF4_SBS());
    nf4_dq_pack(scales2, nb, q8, supers);
    var scales_r = t_alloc(nb);
    nf4_dq_unpack(q8, supers, nb, scales_r);
    var amax_s = f64_from(0);
    i = 0;
    while (i < nb) {
        var a = load64(scales2 + i * 8);
        if (f64_gt(a, amax_s) == 1) { amax_s = a; }
        i = i + 1;
    }
    var lim2 = f64_div(amax_s, f64_from(250));            # ≥ amax/254 with margin
    bad = 0;
    i = 0;
    while (i < nb) {
        var e = _absf(f64_sub(load64(scales2 + i * 8), load64(scales_r + i * 8)));
        if (f64_gt(e, lim2) == 1) { bad = bad + 1; }
        i = i + 1;
    }
    assert_eq(bad, 0, "double-quant reconstructs every scale within amax/250");
    return 0;
}

fn main(): i64 {
    alloc_init();
    test_nf4();
    return assert_summary();
}

var rc = main();
syscall(60, rc);

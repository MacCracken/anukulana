# tests/tcyr/smoke.tcyr — anukulana scaffold smoke (M0).
include "src/lib.cyr"
include "lib/assert.cyr"

fn test_version() {
    assert_eq(anukulana_version(), 500, "version 0.5.0 packs to 500");
    return 0;
}

fn main(): i64 {
    alloc_init();
    test_version();
    return assert_summary();
}

var rc = main();
syscall(60, rc);

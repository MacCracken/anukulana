# tests/tcyr/gguf.tcyr — GGUF import: parser + GPT-2 mapping round-trip.
#
# Mirrors gpt2.tcyr's self-contained pattern: build a model in rupantara's
# packed layout, EXPORT it as a llama.cpp-shaped GGUF (blk.N.* names, ggml
# [out, in] row-major weights — i.e. the writer TRANSPOSES, fused qkv, F32
# data, ne-order dims with dims[0] innermost), then IMPORT via
# anuk_ggpt2_infer_cfg + anuk_ggpt2_pack and assert (a) packed params
# bit-identical and (b) ru_model_fwd logits bit-identical.
#
# Seed values are chosen EXACT in f32 (small ints over a power-of-two
# denominator), so f64 -> f32 -> f64 is lossless and the bit-identity gates are
# legitimate. A minimal-file test also covers the F16 widen path, KV lookups
# (incl. non-default alignment + structurally-skipped array/string values) and
# directed structural rejects; the mutation/truncation sweep lives in
# tests/tcyr/fuzz.tcyr.
include "src/lib.cyr"
include "lib/assert.cyr"

# ---- f64 -> f32/f16 bit narrowing (test values are exact + in range) ----------
fn _n_f32(d): i64 {
    var s = (d >> 63) & 1;
    var e = (d >> 52) & 0x7FF;
    var m = d & 0xFFFFFFFFFFFFF;
    if (e == 0) { return s << 31; }                  # ±0 (no denormals in seeds)
    return (s << 31) | ((e - 1023 + 127) << 23) | (m >> 29);
}
fn _n_f16(d): i64 {
    var s = (d >> 63) & 1;
    var e = (d >> 52) & 0x7FF;
    var m = d & 0xFFFFFFFFFFFFF;
    if (e == 0) { return s << 15; }
    return (s << 15) | ((e - 1023 + 15) << 10) | (m >> 42);
}

# ---- a minimal GGUF WRITER ----------------------------------------------------
# w: +0 buf | +8 off | +16 ntens | +24 tensor table (ntens × 48:
#    name data(f64) ne0 ne1 ndim gtype)  — serialized by _ggw_finish.
fn _ggw_new(): i64 {
    var w = alloc(32 + 64 * 48);
    store64(w, 0); store64(w + 8, 0); store64(w + 16, 0);
    return w;
}
fn _ggw_add(w, name, data, ne0, ne1, ndim, gtype): i64 {
    var t = w + 32 + load64(w + 16) * 48;
    store64(t, name); store64(t + 8, data);
    store64(t + 16, ne0); store64(t + 24, ne1);
    store64(t + 32, ndim); store64(t + 40, gtype);
    store64(w + 16, load64(w + 16) + 1);
    return 0;
}
fn _ggw_u8(buf, offp, v): i64 {
    store8(buf + load64(offp), v & 0xFF);
    store64(offp, load64(offp) + 1);
    return 0;
}
fn _ggw_u32(buf, offp, v): i64 {
    var i = 0;
    while (i < 4) { _ggw_u8(buf, offp, v >> (i * 8)); i = i + 1; }
    return 0;
}
fn _ggw_u64(buf, offp, v): i64 {
    var i = 0;
    while (i < 8) { _ggw_u8(buf, offp, v >> (i * 8)); i = i + 1; }
    return 0;
}
fn _ggw_str(buf, offp, s): i64 {
    var n = strlen(s);
    _ggw_u64(buf, offp, n);
    var i = 0;
    while (i < n) { _ggw_u8(buf, offp, load8(s + i)); i = i + 1; }
    return 0;
}
fn _ggw_kv_u32(buf, offp, key, v): i64 {
    _ggw_str(buf, offp, key); _ggw_u32(buf, offp, 4); _ggw_u32(buf, offp, v);
    return 0;
}
fn _ggw_kv_str(buf, offp, key, v): i64 {
    _ggw_str(buf, offp, key); _ggw_u32(buf, offp, 8); _ggw_str(buf, offp, v);
    return 0;
}
fn _ggw_tne(t, k): i64 { if (k == 0) { return load64(t + 16); } return load64(t + 24); }
fn _ggw_tnelems(t): i64 {
    var n = load64(t + 16);
    if (load64(t + 32) == 2) { n = n * load64(t + 24); }
    return n;
}

# serialize: header + KVs (arch/dims/alignment + skip-fodder) + infos + data.
# kvmode 1 = the GPT-2 metadata set; 0 = minimal (arch only + alignment 64).
fn _ggw_finish(w, cfg, alignment, kvmode, out_len): i64 {
    var ntens = load64(w + 16);
    var buf = alloc(4 * 1024 * 1024);
    var offp = alloc(8);
    store64(offp, 0);
    var n_kv = 4;                                    # arch + alignment + arr + str
    if (kvmode == 1) { n_kv = 8; }                   # + C/NL/nh/F
    _ggw_u32(buf, offp, GGUF_MAGIC());
    _ggw_u32(buf, offp, 3);                          # version 3
    _ggw_u64(buf, offp, ntens);
    _ggw_u64(buf, offp, n_kv);
    _ggw_kv_str(buf, offp, "general.architecture", "gpt2");
    _ggw_kv_u32(buf, offp, "general.alignment", alignment);
    # skip-fodder: an array KV and a string KV the importer never reads —
    # the walk must skip them structurally
    _ggw_str(buf, offp, "test.skip_array");
    _ggw_u32(buf, offp, 9);                          # vtype array
    _ggw_u32(buf, offp, 4);                          # elem type u32
    _ggw_u64(buf, offp, 3);
    _ggw_u32(buf, offp, 11); _ggw_u32(buf, offp, 22); _ggw_u32(buf, offp, 33);
    _ggw_kv_str(buf, offp, "test.skip_str", "ignored");
    if (kvmode == 1) {
        _ggw_kv_u32(buf, offp, "gpt2.embedding_length", _cfg_C(cfg));
        _ggw_kv_u32(buf, offp, "gpt2.block_count", _cfg_NL(cfg));
        _ggw_kv_u32(buf, offp, "gpt2.attention.head_count", _cfg_nh(cfg));
        _ggw_kv_u32(buf, offp, "gpt2.feed_forward_length", _cfg_F(cfg));
    }
    # tensor infos (data offsets assigned sequentially, each alignment-aligned)
    var doff = 0;
    var i = 0;
    while (i < ntens) {
        var t = w + 32 + i * 48;
        var gtype = load64(t + 40);
        var esz = 4;
        if (gtype == 1) { esz = 2; }
        _ggw_str(buf, offp, load64(t));
        _ggw_u32(buf, offp, load64(t + 32));         # n_dims
        var k = 0;
        while (k < load64(t + 32)) { _ggw_u64(buf, offp, _ggw_tne(t, k)); k = k + 1; }
        _ggw_u32(buf, offp, gtype);
        doff = doff + (alignment - (doff % alignment)) % alignment;
        _ggw_u64(buf, offp, doff);
        doff = doff + _ggw_tnelems(t) * esz;
        i = i + 1;
    }
    # pad header to alignment, then write data blobs at their offsets
    var hend = load64(offp);
    var dstart = hend + (alignment - (hend % alignment)) % alignment;
    while (load64(offp) < dstart) { _ggw_u8(buf, offp, 0); }
    doff = 0;
    i = 0;
    while (i < ntens) {
        var t2 = w + 32 + i * 48;
        var gtype2 = load64(t2 + 40);
        var esz2 = 4;
        if (gtype2 == 1) { esz2 = 2; }
        doff = doff + (alignment - (doff % alignment)) % alignment;
        store64(offp, dstart + doff);
        var src = load64(t2 + 8);
        var ne = _ggw_tnelems(t2);
        var j = 0;
        while (j < ne) {
            var d = load64(src + j * 8);
            if (gtype2 == 0) { _ggw_u32(buf, offp, _n_f32(d)); }
            else {
                var h = _n_f16(d);
                _ggw_u8(buf, offp, h); _ggw_u8(buf, offp, h >> 8);
            }
            j = j + 1;
        }
        doff = doff + ne * esz2;
        i = i + 1;
    }
    store64(out_len, dstart + doff);
    return buf;
}

# ---- minimal-file test: KVs, F32 + F16 widen, directed rejects ---------------
fn test_gguf_minimal(): i64 {
    var a = t_alloc(3);
    tset(a, 0, f64_div(f64_from(3), f64_from(2)));       # 1.5
    tset(a, 1, f64_div(f64_from(0 - 9), f64_from(4)));   # -2.25
    tset(a, 2, f64_from(7));
    var b = t_alloc(4);
    tset(b, 0, f64_div(f64_from(1), f64_from(2)));
    tset(b, 1, f64_from(0 - 1));
    tset(b, 2, f64_from(2));
    tset(b, 3, f64_div(f64_from(0 - 1), f64_from(4)));
    var w = _ggw_new();
    _ggw_add(w, "t.f32", a, 3, 0, 1, 0);
    _ggw_add(w, "t.f16", b, 2, 2, 2, 1);
    var lenp = alloc(8);
    var buf = _ggw_finish(w, 0, 64, 0, lenp);            # non-default alignment
    var len = load64(lenp);

    var r = gg_open(buf, len);
    assert_nonnull(r, "gg_open accepts the valid file");
    assert_eq(gg_count(r), 2, "two tensors");
    var e = gg_find(r, "t.f32");
    assert_nonnull(e, "gg_find t.f32");
    assert_eq(gg_entry_ndim(e), 1, "t.f32 ndim");
    assert_eq(gg_entry_nelems(e), 3, "t.f32 nelems");
    var out = t_alloc(3);
    assert_eq(gg_read_f64(r, e, out), 3, "t.f32 read");
    assert_eq(load64(out), load64(a), "f32 widen exact [0]");
    assert_eq(load64(out + 8), load64(a + 8), "f32 widen exact [1]");
    assert_eq(load64(out + 16), load64(a + 16), "f32 widen exact [2]");
    var e2 = gg_find(r, "t.f16");
    assert_nonnull(e2, "gg_find t.f16");
    assert_eq(gg_entry_dim(e2, 0), 2, "t.f16 ne0");
    assert_eq(gg_entry_dim(e2, 1), 2, "t.f16 ne1");
    var out2 = t_alloc(4);
    assert_eq(gg_read_f64(r, e2, out2), 4, "t.f16 read");
    var k = 0;
    var f16ok = 1;
    while (k < 4) {
        if (load64(out2 + k * 8) != load64(b + k * 8)) { f16ok = 0; }
        k = k + 1;
    }
    assert_eq(f16ok, 1, "f16 widen exact");
    assert_eq(gg_find(r, "t.absent"), 0, "absent tensor -> 0");
    # KV surface
    var fnd = alloc(8);
    assert_eq(gg_kv_int(r, "general.alignment", fnd), 64, "alignment KV read");
    assert_eq(load64(fnd), 1, "alignment KV found");
    gg_kv_int(r, "no.such.key", fnd);
    assert_eq(load64(fnd), 0, "absent KV -> found=0");
    var slen = alloc(8);
    var sp = gg_kv_str(r, "general.architecture", slen);
    assert_nonnull(sp, "arch KV string");
    assert_eq(load64(slen), 4, "arch KV len");
    assert_eq(load8(sp + 3), 50, "arch KV ends in '2'");
    assert_eq(gg_kv_str(r, "general.alignment", slen), 0, "int KV via str -> 0");
    # directed structural rejects (byte-level; fuzz.tcyr does the sweep)
    assert_eq(gg_open(buf, 10), 0, "truncated header rejected");
    store8(buf + 0, 88);
    assert_eq(gg_open(buf, len), 0, "bad magic rejected");
    store8(buf + 0, 71);                                 # 'G' restored
    store8(buf + 4, 1);
    assert_eq(gg_open(buf, len), 0, "version 1 rejected");
    store8(buf + 4, 3);
    assert_nonnull(gg_open(buf, len), "restored file accepted again");
    return 0;
}

# ---- GPT-2 export -> import round-trip ---------------------------------------
fn _t2d(src, rows_in, cols_out): i64 {
    # rupantara [in, out] row-major -> ggml [out, in] row-major
    var t = alloc(rows_in * cols_out * 8);
    var o = 0;
    while (o < cols_out) {
        var i = 0;
        while (i < rows_in) {
            store64(t + (o * rows_in + i) * 8, load64(src + (i * cols_out + o) * 8));
            i = i + 1;
        }
        o = o + 1;
    }
    return t;
}
fn _gnm(L, suffix): i64 { return _ggpt2_name(0, L, suffix); }

fn _export_gguf(cfg, P, out_len): i64 {
    var V = _cfg_V(cfg); var C = _cfg_C(cfg); var T = _cfg_T(cfg);
    var NL = _cfg_NL(cfg); var F = _cfg_F(cfg);
    var w = _ggw_new();
    _ggw_add(w, "token_embd.weight", _p_tokemb(P), C, V, 2, 0);      # ne=[C,V]
    _ggw_add(w, "position_embd.weight", _p_posemb(P, cfg), C, T, 2, 0);
    var L = 0;
    while (L < NL) {
        var pblk = P + _ru_blk_base(cfg, L) * 8;
        _ggw_add(w, _gnm(L, "attn_norm.weight"), pblk + _ru_o_ln1g(cfg) * 8, C, 0, 1, 0);
        _ggw_add(w, _gnm(L, "attn_norm.bias"), pblk + _ru_o_ln1b(cfg) * 8, C, 0, 1, 0);
        # fused qkv in ggml orientation: [3C, C] row-major, q rows then k then v
        var tq = _t2d(pblk + _ru_o_Wq(cfg) * 8, C, C);
        var tk = _t2d(pblk + _ru_o_Wk(cfg) * 8, C, C);
        var tv = _t2d(pblk + _ru_o_Wv(cfg) * 8, C, C);
        var cat = alloc(3 * C * C * 8);
        t_copy(cat, tq, C * C);
        t_copy(cat + C * C * 8, tk, C * C);
        t_copy(cat + 2 * C * C * 8, tv, C * C);
        _ggw_add(w, _gnm(L, "attn_qkv.weight"), cat, C, 3 * C, 2, 0); # ne=[C,3C]
        var catb = alloc(3 * C * 8);
        t_copy(catb, _bq(cfg, pblk), C);
        t_copy(catb + C * 8, _bk(cfg, pblk), C);
        t_copy(catb + 2 * C * 8, _bv(cfg, pblk), C);
        _ggw_add(w, _gnm(L, "attn_qkv.bias"), catb, 3 * C, 0, 1, 0);
        _ggw_add(w, _gnm(L, "attn_output.weight"), _t2d(pblk + _ru_o_Wo(cfg) * 8, C, C), C, C, 2, 0);
        _ggw_add(w, _gnm(L, "attn_output.bias"), _bo(cfg, pblk), C, 0, 1, 0);
        _ggw_add(w, _gnm(L, "ffn_norm.weight"), pblk + _ru_o_ln2g(cfg) * 8, C, 0, 1, 0);
        _ggw_add(w, _gnm(L, "ffn_norm.bias"), pblk + _ru_o_ln2b(cfg) * 8, C, 0, 1, 0);
        _ggw_add(w, _gnm(L, "ffn_up.weight"), _t2d(pblk + _ru_o_Wfc(cfg) * 8, C, F), C, F, 2, 0);
        _ggw_add(w, _gnm(L, "ffn_up.bias"), pblk + _ru_o_bfc(cfg) * 8, F, 0, 1, 0);
        _ggw_add(w, _gnm(L, "ffn_down.weight"), _t2d(pblk + _ru_o_Wproj(cfg) * 8, F, C), F, C, 2, 0);
        _ggw_add(w, _gnm(L, "ffn_down.bias"), pblk + _ru_o_bproj(cfg) * 8, C, 0, 1, 0);
        L = L + 1;
    }
    _ggw_add(w, "output_norm.weight", _p_lnfg(P, cfg), C, 0, 1, 0);
    _ggw_add(w, "output_norm.bias", _p_lnfb(P, cfg), C, 0, 1, 0);
    return _ggw_finish(w, cfg, 32, 1, out_len);
}

# f32-EXACT fill: small ints over 32 (lossless through the f32 narrow/widen)
fn _fill32(p, n, seed): i64 {
    var i = 0;
    while (i < n) {
        var m = ((i * 131 + seed * 17 + 7) % 101) - 50;
        store64(p + i * 8, f64_div(f64_from(m), f64_from(32)));
        i = i + 1;
    }
    return 0;
}

fn test_gguf_gpt2_roundtrip(): i64 {
    var V = 13; var C = 8; var T = 6; var nh = 2; var NL = 2;
    var cfg = alloc(64);
    ru_cfg_init(cfg, V, C, T, nh, nh, NL, 4 * C, 1);
    var np = ru_params_count(cfg);
    var P = t_alloc(np);
    _fill32(P, np, 3);
    var lenp = alloc(8);
    var buf = _export_gguf(cfg, P, lenp);
    var r = gg_open(buf, load64(lenp));
    assert_nonnull(r, "gg_open parsed the exported GPT-2 GGUF");
    assert_eq(gg_count(r), 4 + 12 * NL, "tensor count");
    var cfg2 = alloc(64);
    assert_eq(anuk_ggpt2_infer_cfg(r, cfg2, T), 0, "ggpt2 infer_cfg ok");
    assert_eq(_cfg_V(cfg2), V, "inferred V");
    assert_eq(_cfg_C(cfg2), C, "inferred C");
    assert_eq(_cfg_T(cfg2), T, "inferred T");
    assert_eq(_cfg_NL(cfg2), NL, "inferred NL");
    assert_eq(_cfg_F(cfg2), 4 * C, "inferred F");
    assert_eq(ru_params_count(cfg2), np, "inferred params count matches");
    var P2 = t_alloc(np);
    assert_eq(anuk_ggpt2_pack(r, cfg2, P2), 0, "anuk_ggpt2_pack ok");
    var diffs = 0;
    var i = 0;
    while (i < np) {
        if (load64(P2 + i * 8) != load64(P + i * 8)) { diffs = diffs + 1; }
        i = i + 1;
    }
    assert_eq(diffs, 0, "imported params bit-identical to the original");
    var tokens = alloc(T * 8);
    var t = 0;
    while (t < T) { store64(tokens + t * 8, (t * 5 + 2) % V); t = t + 1; }
    var L1 = t_alloc(T * V);
    var L2 = t_alloc(T * V);
    ru_model_fwd(cfg, P, tokens, L1, 0);
    ru_model_fwd(cfg2, P2, tokens, L2, 0);
    var ldiff = 0;
    i = 0;
    while (i < T * V) {
        if (load64(L1 + i * 8) != load64(L2 + i * 8)) { ldiff = ldiff + 1; }
        i = i + 1;
    }
    assert_eq(ldiff, 0, "GGUF-imported model logits bit-identical");
    return 0;
}

fn main(): i64 {
    alloc_init();
    test_gguf_minimal();
    test_gguf_gpt2_roundtrip();
    return assert_summary();
}

var rc = main();
syscall(60, rc);
